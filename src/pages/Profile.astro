---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navigation />
  <section class="profile-page">

    <h1>PROFILE</h1>
    <section class="newsletter">
<label for="email">
      DON'T MISS NEWS AND EVENTS
    </label>

    <div class="newsletter-form">
      <input
        type="email"
        id="email"
        placeholder="EMAIL ADDRESS"
 >

      <button type="submit">
        SIGN UP
      </button>
    </div>
    </section>
  </section>

<Footer/>
  </Layout>
  <style>

.newsletter{
 width: 100vw;}

.profile-page{
    padding: 40px;
   
    
    }

    .newsletter{
      display:flex;
  flex-direction:column;
  gap:32px;
}

.newsletter label{
  font-size:13px;
  font-weight:700;
}

.newsletter-form{
  display:flex;
  border-bottom:1px solid black;
}

.newsletter input{
  flex:1;

  border:none;
  outline:none;
  background:transparent;

  padding:12px 0;

  font-size:13px;
}

.newsletter input::placeholder{
  color:#bdbdbd;
}

.newsletter button{
  border:1px solid black;

  background:black;
  color:white;

  padding:12px 22px;

  font-size:12px;
  font-weight:700;

  cursor:pointer;

  transition:0.3s;
}

.newsletter button:hover{
  background:white;
  color:black;
}

</style>