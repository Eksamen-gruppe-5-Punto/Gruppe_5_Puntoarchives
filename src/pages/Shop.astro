---
//@ts-nocheck
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Filterbox from "../components/Filterbox.astro";
import Cardrack from "../components/Cardrack.astro";
import Footer from "../components/Footer.astro";
import Features from "../components/Features.astro";
import Pcard from "../components/Pcard.astro";
import "../styles/global.css";

const endpoint =
  "https://mpbvcoonbwvxvdnpsfil.supabase.co/rest/v1/punto?select=*&order=id.asc";

const options = {
  headers: {
    apikey: "sb_publishable_cUMJsCe6DpyMi4ezeOFtcg_VUrw2EXt",
  },
};

const data = await fetch(endpoint, options).then((res) => res.json());

console.log(data);
---

<Layout>
  <Navigation />

  <main class="shop-page">
    <section class="shop-hero">
      <h1>SHOP</h1>
    </section>

    <button class="filter-open-btn" id="openFilter" type="button">
      FILTER
    </button>

    <Filterbox />

    <h4 class="shop-quote">
      “Our products are handpicked by<br />
      our own curator in Italy” - PUNTO
    </h4>
  </main>

<main class="shop-racks">
  <Cardrack products={data} />
</main>

    <Features />
  <Footer />
</Layout>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const openBtn = document.querySelector("#openFilter");
    const filterBox = document.querySelector("#filterBox");
    const closeBtn = document.querySelector("#closeFilter");
    const filterButtons = document.querySelectorAll(".filter-btn");
    const resetButton = document.querySelector(".btn.reset-filter");


    if (!openBtn || !filterBox || !closeBtn) return;

    /* ÅBN FILTER */
    openBtn.addEventListener("click", () => {
      filterBox.classList.add("is-open");
    });

    /* LUK FILTER */
    closeBtn.addEventListener("click", () => {
      filterBox.classList.remove("is-open");
    });

    /* FILTER BUTTONS */
    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        button.classList.toggle("selected");
      });
    });

    /* RESET FILTER */
    if (resetButton) {
      resetButton.addEventListener("click", (event) => {
        event.preventDefault();

        filterButtons.forEach((button) => {
          button.classList.remove("selected");
        });

        document.querySelectorAll(".checkbox-list input").forEach((checkbox) => {
          checkbox.checked = false;
        });
      });
    }
  });
</script>

<style>
  .shop-page {
    padding: 32px 20px 40px;
  }

  .shop-hero h2 {
    margin-top: 40px;
    font-size: 44px;
    font-weight: 400;
    letter-spacing: 0.88px;
  }

  .filter-open-btn {
    position: sticky;
    top: 100px;
    margin-left: auto;
    display: block;
    z-index: 2000;
    background: transparent;
    border: none;
    cursor: pointer;
    font-size: 16px;
  }

  .shop-quote {
    display: none;
  }

  .shop-racks {
    display: flex;
    flex-direction: column;
    gap: 60px;
  }
@media (min-width: 1280px) {
  .shop-page {
    position: relative;

    width: calc(100% - 114px);
    margin-left: 57px;

    padding: 55px 0 0;
  }

  .shop-hero h2 {
    margin-top: 40px;
  }

  .shop-quote {
    display: block;

    position: absolute;

    left: 38%;
    top: 250px;

    max-width: 430px;

    font-size: 20px;
    line-height: 1.15;

    font-style: italic;
    font-weight: 100;
  }

  .shop-racks {
    margin-top: -20px;
    gap: 0;
  }
}
  
</style>