---
import Layout from "../layouts/Layout.astro"
---
<Layout>
<section class="our-universe">
  <div class="content-wrapper">
    <h2>OUR UNIVERSE</h2>
    <hr class="divider">
    
    <div class="text-block">
      <p>Punto Archives is more than a curated vintage fashion project. It is an ongoing visual archive of timeless menswear, refined tailoring, and understated elegance. Each piece is carefully selected for its character, craftsmanship, and ability to exist effortlessly between past and present.</p>
      <p class="desktop-only">To experience the full world of Punto Archives, explore our social platforms where the collection comes to life through editorials, styling videos, behind-the-scenes moments, and daily archival finds. Stay connected with the evolving universe of Punto Archives.</p>
      <p class="desktop-only">Scroll below to explore featured visuals and follow us on social media.</p>
      <a href="#" class="read-more-btn">READ MORE</a>
    </div>

    <div class="social-icons">
      <a href="#" class="icon-circle">IG</a>
      <a href="#" class="icon-circle">TT</a>
      <a href="#" class="icon-circle">FB</a>
    </div>
  </div>

  <div class="image-gallery">
    <div class="gallery-item item-plant">
      <img src="/src/assets/magazine.jpg" alt="Vintage magazine and plant">
    </div>
    <div class="gallery-item item-person">
      <img src="/src/assets/personsuit.jpg" alt="Person wearing a suit">
    </div>
    <div class="gallery-item item-jacket">
      <img src="/src/assets/plaidjacket.jpg" alt="Close-up of a plaid jacket">
    </div>
  </div>

</section>
</Layout>