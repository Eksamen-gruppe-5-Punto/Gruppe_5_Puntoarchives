---
//@ts-nocheck
import Pcard from "./Pcard.astro";

const { products } = Astro.props;
---

<section class="card-rack">
  {products.map((product) => (
    <Pcard product={product} />
  ))}
</section>


<style>
  .card-rack {
    width: 100%;

    padding: 0 16px 0;

    display: grid;
    grid-template-columns: 1fr;

    row-gap: 34px;
  }

  .card-rack :global(.card) {
    width: 100%;
  }

  @media (min-width: 900px) {
    .card-rack {
      max-width: 1320px;

      margin: 40px auto 0;

      padding: 0 32px 0;

      display: grid;

      grid-template-columns: repeat(3, 349px);

      justify-content: space-between;

      column-gap: 70px;
      row-gap: 110px;
    }

    .card-rack :global(.card) {
      width: 349px;
    }

.card-rack :global(.card:nth-child(2)) {
      margin-top: 10px;
    }

 .card-rack :global(.card:nth-child(3n + 1)) {
  margin-top: 0;
}

.card-rack :global(.card:nth-child(3n + 2)) {
  margin-top: 170px;
}

.card-rack :global(.card:nth-child(3n + 3)) {
  margin-top: 0;
}
  }
</style>
