---
import Button from "./Button.astro";

const colors = [
  { name: "BLUE", color: "#4c63d9" },
  { name: "BLACK", color: "#000" },
  { name: "GREEN", color: "#4c8b3f" },
  { name: "BEIGE", color: "#eee8d0" },
  { name: "GREY", color: "#ccc" },
  { name: "BROWN", color: "#7b4a3a" },
  { name: "MULTICOLORED" },
];

const sizes = ["XS", "S", "M", "L", "XL", "XXL"];
const materials = ["COTTON", "WOOL", "SILK"];

const sortOptions = [
  "NEW ARRIVALS",
  "HIGHEST PRICE",
  "LOWEST PRICE",
  "SALE",
];
---

<aside class="filter-box" id="filterBox">
  <div class="filter-header">
    <h2>FILTER</h2>
    <button class="close-btn" id="closeFilter" type="button">×</button>
  </div>

  <section>
    <h3>COLOR</h3>
    <div class="button-grid">
      {colors.map((color) => (
        <button class="filter-btn" type="button">
          {color.color && <span style={`background-color:${color.color}`}></span>}
          {color.name}
        </button>
      ))}
    </div>
  </section>

  <section>
    <h3>SIZE</h3>
    <div class="button-grid">
      {sizes.map((size) => (
        <button class="filter-btn" type="button">{size}</button>
      ))}
    </div>
  </section>

  <section>
    <h3>MATERIAL</h3>
    <div class="button-grid">
      {materials.map((material) => (
        <button class="filter-btn" type="button">{material}</button>
      ))}
    </div>
  </section>

  <section>
    <h3>SORT BY</h3>
    <div class="checkbox-list">
      {sortOptions.map((option) => (
        <label>
          <input type="checkbox" />
          {option}
        </label>
      ))}
    </div>
  </section>

  <Button
    text="SHOW PRODUCTS"
    href="#"
    variant="show-products"
  />

  <Button
    text="RESET FILTRE"
    href="#"
    variant="reset-filter"
  />
</aside>

<style>
  .filter-box {
    position: fixed;
    top: 0;
    right: 0;

    width: 30%;
    max-width: 420px;
    min-width: 340px;
    height: 100vh;

    background: white;
    z-index: 4000;

    padding: 24px 20px;
    box-sizing: border-box;

    transform: translateX(100%);
    transition: transform 0.3s ease;

    overflow-y: auto;
  }

  :global(.filter-box.is-open) {
    transform: translateX(0);
  }

  .filter-header {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    margin-bottom: 45px;
  }

  .filter-header h2 {
    font-size: 16px;
    font-weight: 400;
  }

  .close-btn {
    position: absolute;
    right: 0;
    top: -5px;

    background: none;
    border: none;

    font-size: 28px;
    cursor: pointer;
  }

  section {
    margin-bottom: 42px;
  }

  h3 {
    font-size: 16px;
    font-weight: 400;
    margin-bottom: 14px;
  }

  .button-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .filter-btn {
    min-width: 78px;
    height: 31px;
    padding: 0 12px;

    border: 1px solid black;
    background: white;
    color: black;

    font-size: 14px;
    cursor: pointer;

    transition: 0.1s ease;
  }

  .filter-btn.selected {
    background: black;
    color: white;
  }

  .filter-btn span {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    margin-right: 7px;
  }

  .checkbox-list {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .checkbox-list label {
    display: flex;
    align-items: center;

    font-size: 14px;
    cursor: pointer;
  }

  .checkbox-list input {
    appearance: none;

    width: 18px;
    height: 18px;

    border: 1px solid black;
    background: white;

    margin-right: 10px;

    cursor: pointer;
  }

  .checkbox-list input:checked {
    background: black;
  }

  @media (max-width: 700px) {
    .filter-box {
      width: 100%;
      min-width: unset;
      max-width: none;
    }
  }
</style>