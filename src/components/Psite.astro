---
import Button from "./Button.astro";
import "../styles/global.css";
---

<section class="product-section">
  <div class="product-grid">
    <button class="back" type="button" onclick="history.back()">
      BACK
    </button>

    <h1 class="headline">BLAZER</h1>

    <div class="image-frame image-frame-main">
      <img src="https://placehold.co/539x813" alt="Beige Blazer" />
    </div>

    <div class="product-info">
      <p class="product-brand">KENZO</p>
      <h2 class="product-title">Beige Blazer</h2>
      <p class="product-size">Størrelse 52 (L)</p>
      <p class="product-price">649 DKK</p>

      <section
        class="button-test add-to-cart"
        data-brand="KENZO"
        data-name="Beige Blazer"
        data-price="649"
        data-size="52 (L)"
        data-image="https://placehold.co/539x813"
      >
        <Button
          text="ADD TO BAG"
          href="/cart"
          variant="add-to-bag"
        />
      </section>
    </div>

    <div class="description">
      <span class="dropcap">L</span>
      <p>
        orem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod
        tempor incididunt ut labore et dolore Excepteur sint occaecat cupidatat
        non proident, sunt in culpa qui officia deserunt mollit anim id est
        laborum.
      </p>
    </div>

    <div class="image-frame image-frame-bottom">
      <img src="https://placehold.co/539x813" alt="Beige Blazer" />
    </div>

    <img
      class="image-small"
      src="https://placehold.co/290x437"
      alt="Beige Blazer detail"
    />

    <div class="page-number">09</div>
  </div>
</section>

<style>
  .product-section {
    width: 100%;
    background: white;
    padding: 85px 16px 80px;
  }

  .product-grid {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    padding-top: 22px;
  }

  .back {
    display: block;
    position: absolute;
    left: 0;
    top: 0;

    font-size: 18px;

    background: none;
    border: none;
    padding: 0;

    cursor: pointer;
  }

  .headline {
    margin: 24px 0 16px;
    font-weight: 400;
    line-height: 1;
  }

  .image-frame {
    background: #e2e2e2;
    overflow: hidden;
  }

  .image-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-frame-main {
    width: 100%;
    aspect-ratio: 539 / 813;
    margin-bottom: 12px;
  }

  .product-brand {
    margin: 0 0 4px;
    font-family: "Merriweather Sans", sans-serif;
    font-size: 7px;
  }

  .product-title {
    margin: 0 0 4px;
    font-family: "Playfair Display", serif;
    font-size: 12px;
    font-weight: 400;
  }

  .product-size {
    margin: 0 0 8px;
    font-family: "Merriweather Sans", sans-serif;
    font-size: 9px;
  }

  .product-price {
    margin: 0 0 14px;
    font-family: "Playfair Display", serif;
    font-size: 13px;
  }

  .description {
    display: none;
  }

  .image-frame-bottom {
    width: 100%;
    aspect-ratio: 539 / 813;
    margin-bottom: 28px;
  }

  .image-small {
    width: 100%;
    display: block;
  }

  .page-number {
    display: none;
  }

  @media (min-width: 1280px) {
    .product-section {
      padding: 110px 0 80px;
    }

    .product-grid {
      max-width: 1290px;
      height: 1408px;
      position: relative;
      padding-top: 0;
    }

    .back {
      left: 0;
      top: 0;
    }

    .headline {
      position: absolute;
      left: 0;
      top: 34px;
      margin: 0;
      font-size: 64px;
    }

    .image-frame-main {
      position: absolute;
      width: 539px;
      height: 673px;
      left: 0;
      top: 112px;
      margin: 0;
    }

    .image-frame-main img {
      width: 539px;
      height: 813px;
      object-position: center -70px;
    }

    .product-info {
      position: absolute;
      left: 610px;
      top: 230px;
      width: 463px;
    }

    .product-brand {
      display: none;
    }

    .product-title {
      font-size: 32px;
      margin-bottom: 20px;
    }

    .product-size {
      font-size: 14px;
      margin-bottom: 8px;
    }

    .product-price {
      font-size: 28px;
      margin-bottom: 22px;
    }

    .description {
      display: block;
      position: absolute;
      left: 610px;
      top: 470px;
      width: 430px;
      font-family: "Merriweather Sans", sans-serif;
      font-size: 14px;
      line-height: 1.45;
    }

    .description p {
      margin: 0;
    }

    .dropcap {
      float: left;
      font-size: 46px;
      line-height: 0.85;
      margin-right: 6px;
      font-family: "Playfair Display", serif;
    }

    .image-frame-bottom {
      position: absolute;
      width: 497px;
      height: 603px;
      left: 42px;
      top: 830px;
      margin: 0;
    }

    .image-frame-bottom img {
      width: 539px;
      height: 813px;
      object-position: center -140px;
    }

    .image-small {
      position: absolute;
      width: 290px;
      height: 437px;
      left: 580px;
      top: 650px;
      object-fit: cover;
    }

    .page-number {
      display: block;
      position: absolute;
      right: 20px;
      top: 780px;
      font-family: "Playfair Display", serif;
      font-size: 70px;
    }
  }
</style>