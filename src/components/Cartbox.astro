---
import Button from "./Button.astro";
---

<aside class="cart-box" id="cartBox">
  <div class="cart-header">
    <h2 id="cartTitle">YOUR CART IS EMPTY (0)</h2>
    <button class="close-cart-btn" id="closeCart">×</button>
  </div>

  <div class="cart-items" id="cartItems"></div>

  <section class="summary" id="cartSummary">
    <h3>SUMMARY</h3>

    <div>
      <span>Sum articles</span>
      <span id="cartSubtotal">0 DKK</span>
    </div>

    <div>
      <span>Shipping</span>
      <span>35 DKK</span>
    </div>
  </section>

  <div class="total" id="cartTotalBox">
    <span>TOTAL</span>
    <span id="cartTotal">0 DKK</span>
  </div>

  <div class="cart-actions">
    <Button text="CHECK OUT" href="/checkout" variant="show-products" />
    <Button text="CONTINUE SHOPPING" href="/shop" variant="reset-filter" />
  </div>
</aside>

<script is:inline>
  const cartBox = document.querySelector("#cartBox");
  const openCart = document.querySelector("#openCart");
  const closeCart = document.querySelector("#closeCart");

  const cartTitle = document.querySelector("#cartTitle");
  const cartItemsContainer = document.querySelector("#cartItems");
  const cartSummary = document.querySelector("#cartSummary");
  const cartTotalBox = document.querySelector("#cartTotalBox");
  const cartSubtotal = document.querySelector("#cartSubtotal");
  const cartTotal = document.querySelector("#cartTotal");

  const shipping = 35;
  let cartItems = [];

  function renderCart() {
    cartItemsContainer.innerHTML = "";

    if (cartItems.length === 0) {
      cartTitle.textContent = "YOUR CART IS EMPTY (0)";
      cartSummary.style.display = "none";
      cartTotalBox.style.display = "none";
      return;
    }

    cartTitle.textContent = `CART (${cartItems.length})`;
    cartSummary.style.display = "block";
    cartTotalBox.style.display = "flex";

    cartItems.forEach((item, index) => {
      cartItemsContainer.innerHTML += `
        <article class="cart-item">
          <img src="${item.image}" alt="${item.name}" />

          <div class="cart-info">
            <div class="cart-top">
              <p class="brand">${item.brand}</p>

              <button class="remove-item" data-index="${index}">
                ×
              </button>
            </div>

            <h3>${item.name}</h3>

            <div class="cart-bottom">
              <span>${item.quantity}</span>
              <span>${item.price} DKK</span>
            </div>
          </div>
        </article>
      `;
    });

    const subtotal = cartItems.reduce((total, item) => {
      return total + item.price * item.quantity;
    }, 0);

    cartSubtotal.textContent = `${subtotal.toLocaleString("da-DK")} DKK`;
    cartTotal.textContent = `${(subtotal + shipping).toLocaleString("da-DK")} DKK`;
  }

  openCart?.addEventListener("click", () => {
    cartBox?.classList.add("is-open");
  });

  closeCart?.addEventListener("click", () => {
    cartBox?.classList.remove("is-open");
  });

  document.addEventListener("click", (event) => {
    const addButton = event.target.closest(".add-to-cart");

    if (!addButton) return;

    event.preventDefault();

    const product = {
      brand: addButton.dataset.brand,
      name: addButton.dataset.name,
      price: Number(addButton.dataset.price),
      image: addButton.dataset.image,
      quantity: 1
    };

    cartItems.push(product);
    renderCart();
    cartBox?.classList.add("is-open");
  });

  document.addEventListener("click", (event) => {
    const removeButton = event.target.closest(".remove-item");

    if (!removeButton) return;

    const index = Number(removeButton.dataset.index);

    cartItems.splice(index, 1);
    renderCart();
  });

  renderCart();
</script>

<style>
  .cart-box {
    position: fixed;
    top: 0;
    right: 0;

    width: 30%;
    max-width: 420px;
    min-width: 340px;
    height: 100vh;

    background: white;
    z-index: 3000;

    padding: 24px 20px;
    box-sizing: border-box;

    transform: translateX(100%);
    transition: transform 0.3s ease;

    overflow-y: auto;
  }

  :global(.cart-box.is-open) {
    transform: translateX(0);
  }

  .cart-header {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    margin-bottom: 45px;
  }

  .cart-header h2 {
    font-size: 16px;
    font-weight: 400;
    margin: 0;
  }

  .close-cart-btn {
    position: absolute;
    right: 0;
    top: -5px;
    background: none;
    border: none;
    font-size: 28px;
    cursor: pointer;
  }

  :global(.cart-item) {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 20px;

    padding-bottom: 22px;
    margin-bottom: 22px;

    border-bottom: 1px solid black;
  }

  :global(.cart-item img) {
    width: 120px;
    height: 170px;
    object-fit: cover;
  }
:global(.cart-top) {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
:global(.remove-item) {
  background: none;
  border: none;
  font-size: 22px;
  cursor: pointer;
  padding: 0;
  line-height: 1;
  margin-top: -1px;
}

:global(.cart-info .brand) {
  font-size: 12px;
  margin: 0;
}

  :global(.cart-info h3) {
    font-size: 16px;
    font-weight: 400;
    margin: 0;
    margin-top: 10px;
  }

  :global(.cart-bottom) {
    display: flex;
    justify-content: space-between;
    margin-top: 70px;
    font-size: 16px;
  }

  .summary {
    border-bottom: 1px solid black;
    padding-bottom: 20px;
    margin-bottom: 28px;
  }

  .summary h3 {
    font-size: 16px;
    font-weight: 400;
    margin-bottom: 24px;
  }

  .summary div,
  .total {
    display: flex;
    justify-content: space-between;
    font-size: 16px;
    margin-bottom: 18px;
  }

  .total {
    font-weight: 700;
  }

  .cart-actions {
    margin-top: 50px;
  }

  @media (max-width: 700px) {
    .cart-box {
      width: 100%;
      max-width: none;
      min-width: unset;
    }
    
    
  }
</style>