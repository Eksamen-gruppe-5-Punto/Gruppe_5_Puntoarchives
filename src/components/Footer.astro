---
import instagram from "../assets/instagram.png";
import tiktok from "../assets/tiktok.png";
import facebook from "../assets/facebooj.png";
import puntoFooter from "../assets/puntofooter.svg";
---

<footer class="footer">
  <div class="footer__inner">
    <section class="footer__menu">
      <h3>PUNTO ARCHIVES</h3>

      <nav>
        <a href="/Shop">Shop</a>
        <a href="/Aboutlookbook">About</a>
        <a href="/Event">Event</a>
        <a href="/vilkaar">Vilkår og Betingelser</a>
      </nav>
    </section>

    <section class="footer__find">
      <h3>FIND US</h3>

      <p>
        Sankt Hans Gade 9, kld. tv,<br />
        2200 København
      </p>

      <p>Punto@gmail.dk</p>
      <p>+45 12 34 56 67</p>
    </section>

    <section class="footer__connect">
      <h3>CONNECT WITH PUNTO</h3>

      <div class="socials">
        <a
          href="https://www.instagram.com/punto.archives/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
        >
          <img src={instagram.src} alt="Instagram" />
        </a>

        <a
          href="https://www.tiktok.com/@puntoarchives"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="TikTok"
        >
          <img src={tiktok.src} alt="TikTok" />
        </a>

        <a
          href="https://www.facebook.com/profile.php?id=61583900019024"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
        >
          <img src={facebook.src} alt="Facebook" />
        </a>
      </div>
    </section>

    <section class="newsletter">
      <h3>DON’T MISS OUR NEWS AND EVENTS</h3>

      <form>
        <input type="email" placeholder="EMAIL ADRESSE" />
        <button type="submit">TILMELD</button>
      </form>
    </section>
  </div>

<img class="footer__logo" src={puntoFooter.src} alt="PUNTO ARCHIVES" />
</footer>



<style>
.footer {
  width: 100%;
  min-height: calc(100vh - 72px);
  padding: 120px 21px 0;
  box-sizing: border-box;
  overflow: hidden;

  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.footer__inner {
  display: grid;
  grid-template-columns: 149px 1fr;
  column-gap: 52px;
  row-gap: 0;
}

.footer section {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.footer h3 {
  margin: 0 0 13px;
  font-size: 13px;
  font-weight: 600;
  line-height: 20px;
  text-transform: uppercase;
}

.footer a,
.footer p {
  margin: 0;
  color: black;
  text-decoration: none;
  font-size: 13px;
  line-height: 20px;
  font-weight: 400;
}

.footer__menu {
  grid-column: 1;
  grid-row: 1;
}

.footer__menu nav {
  display: flex;
  flex-direction: column;
}

.footer__find {
  grid-column: 1;
  grid-row: 2;
  margin-top: 38px;
  margin-bottom: 5px;
}


.footer__connect {
  grid-column: 2;
  grid-row: 1;
  padding-top: 2px;
}

.socials {
  display: flex;
  gap: 14px;
}

.socials img {
  width: 23px;
  height: 23px;
  object-fit: contain;
  display: block;
}

.newsletter {
  grid-column: 1 / -1;
  margin-top: 60px;
}

.newsletter h3 {
  font-size: 14px;
  margin-bottom: 18px;
}

.newsletter form {
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 104px;
  align-items: end;
}

.newsletter input {
  min-width: 0;
  height: 33px;
  border: none;
  border-bottom: 1px solid black;
  background: transparent;
  outline: none;
  font-size: 14px;
  font-weight: 400;
  letter-spacing: 0.84px;
  color: black;
  padding: 0;
}

.newsletter input::placeholder {
  color: #999797;
}

.newsletter button {
  width: 104px;
  height: 33px;
  border: none;
  background: black;
  color: white;
  font-size: 14px;
  font-weight: 400;
  cursor: pointer;
}
.footer__logo {
  width: 108%;
  margin: 40px 0 0 -4%;
    padding-bottom: 20px;
}


  @media (min-width: 1280px) {
    .footer {
      min-height: calc(100vh - 72px);
  padding: 140px 40px 0;
      display: flex;
      flex-direction: column;
    }

    .footer__inner {
      display: grid;
      grid-template-columns: 149px 170px 240px 383px;
      gap: 125px;
      align-items: start;
    }

    .footer__menu,
    .footer__find,
    .footer__connect,
    .newsletter {
      grid-column: auto;
      grid-row: auto;
      margin-top: 0;
    }

    .footer h3 {
      margin: 0 0 24px;
      font-size: 15px;
      line-height: 20px;
    }

    .footer a,
    .footer p {
      margin: 0 0 12px;
      font-size: 15px;
      line-height: 20px;
    }

    .socials {
      gap: 14px;
    }

    .socials img {
      width: 33px;
      height: 33px;
    }

    .newsletter form {
      display: flex;
      border-bottom: 1px solid black;
    }

    .newsletter input {
      flex: 1;
      height: auto;
      border-bottom: none;
      font-size: 15px;
      letter-spacing: 0.9px;
      padding-bottom: 8px;
    }

    .newsletter button {
      width: 104px;
      height: 33px;
      font-size: 15px;
    }
  
 .footer__logo {
  width: calc(100% + 80px);
  max-width: none;
    height: 190px;

  object-fit: contain;


  margin: 90px 0 0 -40px;
}

}

</style>