---
import Cartbox from "../components/Cartbox.astro";
import suitpaastol from "../assets/suitpaastol.webp";
import kaareogida from "../assets/kaareogida.webp";
---

<header class="header" id="siteHeader">
  <div class="menu">
    <button
      class="menu-btn"
      id="menuButton"
      aria-controls="menuDropdown"
      aria-expanded="false"
      aria-haspopup="true"
      type="button"
    >
      MENU
    </button>

    <div class="dropdown" id="menuDropdown" role="menu" aria-hidden="true">

      <!-- LEFT -->
      <div class="dropdown-left" aria-label="Main menu">

        <a href="/" role="menuitem" tabindex="-1">
          HOME <span class="arrow"> 〉 </span>
        </a>

        <a
          href="/Shop"
          role="menuitem"
          tabindex="-1"
          id="shopToggle"
        >
          SHOP <span class="arrow"> 〉</span>
        </a>

        <div class="shop-submenu" id="shopSubmenu">
          <a href="/Shop">SHOP ALL</a>
          <a href="/Shop">BLAZERE</a>
          <a href="/Shop">SUITS</a>
        </div>

        <a href="/Aboutlookbook" role="menuitem" tabindex="-1">
          ABOUT US & LOOKBOOK <span class="arrow"> 〉 </span>
        </a>

        <a href="/Event" role="menuitem" tabindex="-1">
          EVENTS <span class="arrow"> 〉 </span>
        </a>

      </div>

      <!-- RIGHT -->
      <div class="dropdown-right" aria-label="News">

        <a class="news-card" href="/">
          <div class="news-meta">
            <span class="news-number">01</span>
            <span class="news-label">NEWS</span>
          </div>

          <img
            class="news-image"
            src={suitpaastol.src}
            alt="News 01"
            loading="lazy"
          />
        </a>

        <a class="news-card" href="/Event">
          <div class="news-meta">
            <span class="news-number">02</span>
            <span class="news-label">NEXT EVENT</span>
          </div>

          <img
            class="news-image"
            src={kaareogida.src}
            alt="News 02"
            loading="lazy"
          />
        </a>

      </div>
    </div>
  </div>

  <a href="/" class="logo">
    <span>PUNTO</span>
    <div class="dot"></div>
  </a>

  <nav>
    <a href="/Profile">PROFILE</a>

    <button class="bag-btn" id="openCart">
      BAG
    </button>
  </nav>
</header>

<!-- Backdrop -->
<div class="menu-backdrop" id="menuBackdrop" aria-hidden="true"></div>

<!-- CART -->
<Cartbox />

<style>
  :root {
    --header-height: 72px;
  }

  /* HEADER */

  .header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: start;

    padding: 20px 16px;

    position: fixed;
    top: 0;
    left: 0;
    right: 0;

    z-index: 3000;

    background: #fff;
  }

  .header.menu-open {
    background: #fff;
  }

  /* MENU + LINKS + BAG */

  .menu-btn,
  nav a,
  .bag-btn {
    background: none;
    border: none;

    padding: 0 0 4px;

    cursor: pointer;

    font-size: 16px;
    line-height: 1;

    color: black;

    font-family: "Bodoni 72", serif;

    text-decoration: none;

    justify-self: start;

    position: relative;
  }

  .menu-btn::after,
  nav a::after,
  .bag-btn::after {
    content: '';

    position: absolute;

    bottom: 0;
    left: 0;

    width: 100%;
    height: 1px;

    background-color: black;

    transform: scaleX(0);
    transform-origin: center;

    transition: transform 0.3s ease;
  }

  .menu-btn:hover::after,
  nav a:hover::after,
  .bag-btn:hover::after {
    transform: scaleX(1);
  }

  /* LOGO */

  .logo {
    display: flex;
    flex-direction: column;
    align-items: center;

    text-decoration: none;

    color: black;
  }

  .logo span {
    font-size: 16px;
    line-height: 1;

    font-family: "Playfair Display", serif;
  }

  .dot {
    width: 5px;
    height: 5px;

    border-radius: 999px;

    background: black;

    margin-top: 6px;
  }

  nav {
    display: flex;
    gap: 16px;

    justify-self: end;
  }

  .menu {
    position: relative;
    display: inline-block;

    justify-self: start;
  }

  /* MOBILE FIRST DROPDOWN */
.dropdown {
  position: fixed;

  left: 0;
  top: var(--header-height);

  width: 100%;
   min-height: unset;

 height: calc(100dvh - var(--header-height));

  box-sizing: border-box;

  background: #fff;

  visibility: hidden;
  opacity: 0;
   padding-bottom: 140px;

  transform: translateY(-16px);

  transition:
    opacity 0.18s ease,
    transform 0.22s ease,
    visibility 0s linear 0.22s;

  pointer-events: none;

  z-index: 1000;

  padding: 48px 24px;

  display: grid;
  grid-template-columns: 1fr;

  gap: 56px;

  overflow-x: hidden;
  overflow-y: auto;

  -webkit-overflow-scrolling: touch;
  
}

  .dropdown.open {
    visibility: visible;
    opacity: 1;

    transform: translateY(0);

    transition:
      opacity 0.18s ease,
      transform 0.22s ease;

    pointer-events: auto;
  }

  /* LEFT SIDE */

  .dropdown-left {
    display: flex;
    flex-direction: column;

    gap: 34px;

    align-items: flex-start;

    position: relative;
  }

  .dropdown-left a {
    padding: 0 0 6px;

    font-size: 16px;

    font-family: "Bodoni 72", serif;

    display: flex;
    align-items: baseline;

    gap: 14px;

    color: black;

    text-decoration: none;

    position: relative;

    width: fit-content;
  }

  .dropdown-left a::after,
  .shop-submenu a::after {
    content: '';

    position: absolute;

    left: 0;
    bottom: 0;

    width: 100%;
    height: 1px;

    background: black;

    transform: scaleX(0);
    transform-origin: center;

    transition: transform 0.3s ease;
  }

  .dropdown-left a:hover::after,
  .dropdown-left a:focus-visible::after,
  .shop-submenu a:hover::after,
  .shop-submenu a:focus-visible::after {
    transform: scaleX(1);
  }

  /* SHOP SUBMENU */

  .shop-submenu {
    position: static;

    display: none;
    flex-direction: column;

    margin-left: 28px;
    margin-top: -12px;

    gap: 16px;
  }

  .shop-submenu.open {
    display: flex;
  }

  .shop-submenu a {
    font-size: 14px;

    font-family: "Bodoni 72", serif;

    color: black;

    text-decoration: none;

    position: relative;

    width: fit-content;

    padding-bottom: 6px;
  }

  .arrow {
    margin-left: 10px;
  }

  /* RIGHT SIDE */

 .dropdown-right {
  width: 100%;
  display: grid;
  grid-template-columns: 1fr;
  gap: 28px;
    padding-bottom: 80px;
}

  .news-card {
    width: 100%;
    max-width: 100%;

    overflow: hidden;

    text-decoration: none;

    color: black;
  }

  .news-meta {
    display: flex;
    align-items: baseline;

    gap: 2px;

    margin-bottom: 10px;

    font-size: 14px;

    font-family: "Bodoni 72", serif;
  }

  .news-number {
    font-size: 22px;
     padding-right: 5px;
  }
  .news-label {
    font-size: 16px;
  }
  .news-image {
  width: 100%;
  max-width: 320px;
  height: auto;
  aspect-ratio: 320 / 230;
  object-fit: cover;
  display: block;
}

  .news-card:first-child .news-image {
    object-position: center 40%;
  }

  .news-card:nth-child(2) .news-image {
    object-position: center;
  }

  .news-card:hover .news-image,
  .news-card:focus-visible .news-image {
    transform: scale(1.02);
  }

  /* BACKDROP */

  .menu-backdrop {
    position: fixed;

    left: 0;
    right: 0;
    bottom: 0;

    top: var(--header-height);

    background: rgba(0, 0, 0, 0.45);

    opacity: 0;
    visibility: hidden;

    transition:
      opacity 0.18s ease,
      visibility 0s linear 0.18s;

    pointer-events: none;

    z-index: 900;
  }

  .menu-backdrop.open {
    opacity: 1;
    visibility: visible;

    transition: opacity 0.18s ease;

    pointer-events: auto;
  }

  /* TABLET */

  @media (min-width: 900px) {

    .dropdown {
      padding: 55px 60px;
    }

    .dropdown-left a {
      font-size: 18px;
    }
  }

  /* DESKTOP */

  @media (min-width: 1280px) {

    .header {
      padding: 36px 60px 15px;
    }

    .menu-btn,
    nav a,
    .bag-btn {
      font-size: 22px;
    }

    .logo span {
      font-size: 22px;
    }

    nav {
      gap: 48px;
    }

    .dropdown {
    width: 100vw;
    height: 490px;
    overflow: visible;

      min-height: unset;

      padding: 55px 60px 0;

      grid-template-columns: 560px 532px;
      align-items: start;
      gap: 68px;

      overflow: visible;
    }

    .dropdown-left a {
      font-size: 22px;
    }

    .news-number {
    font-size: 22px;
    padding-right: 5px;
  }
  .news-label {
    font-size: 14px;
  }

    .dropdown-right {
      display: grid;

      grid-template-columns: 260px 260px;

      gap: 40px;

      justify-content: start;

      margin-left: 120px;
      
    }

     .news-image {
    width: 260px;
    height: 370px;
    max-width: none;
    aspect-ratio: auto;
    
  }

    .shop-submenu {
      position: absolute;
      left: 420px;
      top: 5px;

      margin-left: 0;
      margin-top: 0;

      gap: 22px;
    }
  }

  .menu-backdrop {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;

    /* start below the header so the header stays visible */
    top: var(--header-height);

    background: rgba(0, 0, 0, 0.45);
    opacity: 0;
    visibility: hidden;

    transition: opacity 0.18s ease, visibility 0s linear 0.18s;
    pointer-events: none;

    
    z-index: 900;
  }

  .menu-backdrop.open {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.18s ease;
    pointer-events: auto; 
  }
</style>

<script type="module">
  const header = document.getElementById('siteHeader');
  const btn = document.getElementById('menuButton');
  const dropdown = document.getElementById('menuDropdown');
  const backdrop = document.getElementById('menuBackdrop');

  function syncHeaderHeight() {
    const h = header?.offsetHeight ?? 72;
    document.documentElement.style.setProperty('--header-height', `${h}px`);
  }

  function openMenu() {
    header?.classList.add('menu-open');
    btn?.setAttribute('aria-expanded', 'true');
    dropdown?.setAttribute('aria-hidden', 'false');
    dropdown?.classList.add('open');

    backdrop?.setAttribute('aria-hidden', 'false');
    backdrop?.classList.add('open');
  }

  function closeMenu() {
    header?.classList.remove('menu-open');
    btn?.setAttribute('aria-expanded', 'false');
    dropdown?.setAttribute('aria-hidden', 'true');
    dropdown?.classList.remove('open');

    backdrop?.setAttribute('aria-hidden', 'true');
    backdrop?.classList.remove('open');
  }

  syncHeaderHeight();
  window.addEventListener('resize', syncHeaderHeight);
  window.addEventListener('load', syncHeaderHeight);

  btn?.addEventListener('click', () => {
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    if (isOpen) closeMenu();
    else openMenu();
  });

  // Click on backdrop closes menu
  backdrop?.addEventListener('click', closeMenu);

  document.addEventListener('click', (e) => {
    if (!dropdown?.contains(e.target) && !btn?.contains(e.target)) closeMenu();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
  
</script>
<!-- SCRIPT TIL ÅBEN/LUK KURV -->
<script is:inline>

  /* KNAPPER */
  const openCart = document.querySelector("#openCart");
  const cartBox = document.querySelector("#cartBox");
  const closeCart = document.querySelector("#closeCart");

  /* ÅBN KURV */
  openCart?.addEventListener("click", () => {
    cartBox?.classList.add("is-open");
  });

  /* LUK KURV */
  closeCart?.addEventListener("click", () => {
    cartBox?.classList.remove("is-open");
  });

const shopToggle = document.getElementById('shopToggle');
const shopSubmenu = document.getElementById('shopSubmenu');

shopToggle?.addEventListener('click', (e) => {
  e.preventDefault();

  shopSubmenu?.classList.toggle('open');
});
</script>
