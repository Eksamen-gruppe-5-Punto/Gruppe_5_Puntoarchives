---

---
<header class="header">
  <button class="menu-btn">MENU</button>

  <a href="/" class="logo">
    <span>PUNTO</span>
    <div class="dot"></div>
  </a>

  <nav>
    <a href="/">PROFILE</a>
    <a href="/">BAG</a>
  </nav>
</header>

<style>
  .header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: start;
    padding: 20px 16px;
  }

  .menu-btn,
  nav a {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
    color: black;
    font-family: inherit; /* HUSK AT ÆNDRE FONT */
    text-decoration: none;
    justify-self: start;
    
    /* Gør det muligt at placere stregen præcist under teksten */
    position: relative;
    padding-bottom: 4px; 
  }

  .menu-btn::after,
  nav a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px; 
    background-color: black;
    
    /* noget af hover effekten*/
    transform: scaleX(0);
    transform-origin: center; 
    transition: transform 0.3s ease; 
  }

  /* Hover effekten hvor stregen folder sig ud */
  .menu-btn:hover::after,
  nav a:hover::after {
    transform: scaleX(1);
  }

  .logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: black;
  }

  .logo span {
    font-size: 16px;
    line-height: 1;
  }

  .dot {
    width: 5px;
    height: 5px;
    border-radius: 999px;  /* gør at cirkelen forbliver sig rundt selvom skriftstørrelsen bliver ædnret */
    background: black;
    margin-top: 6px;
  }

  nav {
    display: flex;
    gap: 16px;
    justify-self: end;
  }

  /* DESKTOP */

  @media (min-width: 1280px) {
    .header {
      padding: 20px 16px;
    }

    .menu-btn,
    nav a {
      font-size: 20px;
    }

    .logo span {
      font-size: 20px;
    }

    .dot {
       width: 5px;
    height: 5px;
    border-radius: 999px;  /* gør at cirkelen forbliver sig rundt selvom skriftstørrelsen bliver ædnret */
    background: black;
    margin-top: 6px;
    }

    nav {
      gap: 48px;
    }
  }
</style>
