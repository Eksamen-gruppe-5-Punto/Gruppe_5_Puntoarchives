---
/* IMPORT CARTBOX COMPONENT */
import Cartbox from "../components/Cartbox.astro";
---
<header class="header" id="siteHeader">
  <div class="menu">
    <button
      class="menu-btn"
      id="menuButton"
      aria-controls="menuDropdown"
      aria-expanded="false"
      aria-haspopup="true"
      type="button"
    >
      MENU
    </button>

    <div class="dropdown" id="menuDropdown" role="menu" aria-hidden="true">
      <!-- LEFT: your existing links (kept in same place) -->
      <div class="dropdown-left" aria-label="Main menu">
        <a href="/Shop" role="menuitem" tabindex="-1">SHOP <span class="arrow"> > </span></a>
        <a href="/Aboutlookbook" role="menuitem" tabindex="-1">ABOUT US & LOOKBOOK <span class="arrow"> > </span></a>
        <a href="/Event" role="menuitem" tabindex="-1">EVENTS <span class="arrow"> > </span></a>
      </div>

      <!-- RIGHT: two news items -->
      <div class="dropdown-right" aria-label="News">
        <a class="news-card" href="/news/01">
          <div class="news-meta">
            <span class="news-number">01</span>
            <span class="news-label">NEWS</span>
          </div>
          <img class="news-image" src="/images/news-01.jpg" alt="News 01" loading="lazy" />
        </a>

        <a class="news-card" href="/news/02">
          <div class="news-meta">
            <span class="news-number">02</span>
            <span class="news-label">NEWS</span>
          </div>
          <img class="news-image" src="/images/news-02.jpg" alt="News 02" loading="lazy" />
        </a>
      </div>
    </div>
  </div>

  <a href="/" class="logo">
    <span>PUNTO</span>
    <div class="dot"></div>
  </a>

  <nav>
    <a href="/Profile">PROFILE</a>
    <button class="bag-btn" id="openCart">
      BAG
    </button>
  </nav>
</header>

<!-- Backdrop (darkens the rest of the page) -->
<div class="menu-backdrop" id="menuBackdrop" aria-hidden="true"></div>

<!-- SELVE KURV BOXEN -->
<Cartbox />

<style>
  :root {
    --header-height: 72px;
  }

  .header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: start;
    padding: 20px 16px;

    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 2000; /* make sure header is always above dropdown */

    /* IMPORTANT: no white bar on homepage */
    background: transparent;
  }

  /* When menu is open, header can be white (optional) */
  .header.menu-open {
    background: #fff;
  }

  .menu-btn,
  nav a,
  .bag-btn  {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
    color: black;
    font-family: inherit; /* HUSK AT ÆNDRE FONT */
    text-decoration: none;
    justify-self: start;
    
    /* Gør det muligt at placere stregen præcist under teksten */
    position: relative;
    padding-bottom: 4px; 
  }

 /* MENU + LINKS + BAG */
  .menu-btn::after,
  nav a::after,
   .bag-btn::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px; 
    background-color: black;
    
    /* noget af hover effekten*/
    transform: scaleX(0);
    transform-origin: center; 
    transition: transform 0.3s ease; 
  }

  
  .menu-btn:hover::after,
  nav a:hover::after,  
  .bag-btn:hover::after {
    transform: scaleX(1);
  }

  .logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: black;
  }

  .logo span {
    font-size: 16px;
    line-height: 1;
  }

  .dot {
    width: 5px;
    height: 5px;
    border-radius: 999px;  /* gør at cirkelen forbliver sig rundt selvom skriftstørrelsen bliver ædnret */
    background: black;
    margin-top: 6px;
  }

  nav {
    display: flex;
    gap: 16px;
    justify-self: end;
  }

  
  .menu {
    position: relative;
    display: inline-block;
    justify-self: start;
  }

  /* Dropdown styling (hidden by default) */
  .dropdown {
    position: fixed;
    left: 0;
    top: var(--header-height);

    width: 100vw;
    height: 50vh;
    background: #ffffff;

    visibility: hidden;
    opacity: 0;
    transform: translateY(-16px);
    transition: opacity 0.18s ease, transform 0.22s ease, visibility 0s linear 0.22s;
    pointer-events: none;

    z-index: 1000;
    padding: 48px;

    /* NEW: 2-column layout */
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 48px;
    align-items: start;
  }

  .dropdown.open {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.18s ease, transform 0.22s ease;
    pointer-events: auto;
  }

  /* LEFT links: keep vertical stacking and same look */
  .dropdown-left {
    display: flex;
    flex-direction: column;
    gap: 28px;
    align-items: flex-start;
  }

  /* (your existing .dropdown a styles stay, but now apply to both sides)
     Limit underline effect to JUST the left menu links: */
  .dropdown-left a {
    padding: 0;
    font-size: 18px;
    letter-spacing: 0.02em;
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin: 0;
    color: black;
    text-decoration: none;
    position: relative;
    padding-bottom: 6px;
    width: fit-content;
  }

  .dropdown-left a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: black;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.3s ease;
  }

  .dropdown-left a:hover::after,
  .dropdown-left a:focus-visible::after {
    transform: scaleX(1);
  }

  /* RIGHT: news grid */
  .dropdown-right {
    display: grid;
    grid-template-columns: repeat(2, minmax(180px, 1fr));
    gap: 28px;
    justify-content: end;
    align-items: start;
  }

  .news-card {
    display: block;
    text-decoration: none;
    color: black;
  }

  .news-meta {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 12px;
  }

  .news-number {
    font-size: 22px;
    letter-spacing: 0.02em;
  }

  .news-label {
    font-size: 12px;
    letter-spacing: 0.12em;
  }

  .news-image {
    width: 100%;
    max-width: 450px;
    height: 320px;        /* tweak to match your reference */
    display: block;
    background: #f3f3f3;  /* placeholder color while loading */
    object-fit: cover;
  }

  /* Optional hover: slight zoom */
  .news-card:hover .news-image,
  .news-card:focus-visible .news-image {
    transform: scale(1.02);
  }
  .news-image {
    transition: transform 0.25s ease;
  }

  /* Responsive: stack news under links */
  @media (max-width: 900px) {
    .dropdown {
      grid-template-columns: 1fr;
      height: auto;
      max-height: calc(100vh - var(--header-height));
      overflow: auto;
    }
    .dropdown-right {
      grid-template-columns: 1fr;
    }
    .news-image {
      height: 240px;
    }
  }

  /* DESKTOP */

  @media (min-width: 1280px) {
    .header {
      padding: 20px 16px;
    }

    .menu-btn,
    nav a,  .bag-btn {
      font-size: 20px;
    }

    .logo span {
      font-size: 20px;
    }

    .dot {
       width: 5px;
    height: 5px;
    border-radius: 999px;  /* gør at cirkelen forbliver sig rundt selvom skriftstørrelsen bliver ædnret */
    background: black;
    margin-top: 6px;
    }

    nav {
      gap: 48px;
    }
  }

  .menu-backdrop {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;

    /* start below the header so the header stays visible */
    top: var(--header-height);

    background: rgba(0, 0, 0, 0.45);
    opacity: 0;
    visibility: hidden;

    transition: opacity 0.18s ease, visibility 0s linear 0.18s;
    pointer-events: none;

    
    z-index: 900;
  }

  .menu-backdrop.open {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.18s ease;
    pointer-events: auto; 
  }
</style>

<script type="module">
  const header = document.getElementById('siteHeader');
  const btn = document.getElementById('menuButton');
  const dropdown = document.getElementById('menuDropdown');
  const backdrop = document.getElementById('menuBackdrop');

  function syncHeaderHeight() {
    const h = header?.offsetHeight ?? 72;
    document.documentElement.style.setProperty('--header-height', `${h}px`);
  }

  function openMenu() {
    header?.classList.add('menu-open');
    btn?.setAttribute('aria-expanded', 'true');
    dropdown?.setAttribute('aria-hidden', 'false');
    dropdown?.classList.add('open');

    backdrop?.setAttribute('aria-hidden', 'false');
    backdrop?.classList.add('open');
  }

  function closeMenu() {
    header?.classList.remove('menu-open');
    btn?.setAttribute('aria-expanded', 'false');
    dropdown?.setAttribute('aria-hidden', 'true');
    dropdown?.classList.remove('open');

    backdrop?.setAttribute('aria-hidden', 'true');
    backdrop?.classList.remove('open');
  }

  syncHeaderHeight();
  window.addEventListener('resize', syncHeaderHeight);
  window.addEventListener('load', syncHeaderHeight);

  btn?.addEventListener('click', () => {
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    if (isOpen) closeMenu();
    else openMenu();
  });

  // Click on backdrop closes menu
  backdrop?.addEventListener('click', closeMenu);

  document.addEventListener('click', (e) => {
    if (!dropdown?.contains(e.target) && !btn?.contains(e.target)) closeMenu();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
  
</script>
<!-- SCRIPT TIL ÅBEN/LUK KURV -->
<script is:inline>

  /* KNAPPER */
  const openCart = document.querySelector("#openCart");
  const cartBox = document.querySelector("#cartBox");
  const closeCart = document.querySelector("#closeCart");

  /* ÅBN KURV */
  openCart?.addEventListener("click", () => {
    cartBox?.classList.add("is-open");
  });

  /* LUK KURV */
  closeCart?.addEventListener("click", () => {
    cartBox?.classList.remove("is-open");
  });

</script>
